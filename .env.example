VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_BUCKET=passports
VITE_USE_SERVER_UPLOAD=true

# Server-side upload variables for Vercel
SUPABASE_URL=
